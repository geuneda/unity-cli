{
  "steps": [
    {
      "id": "scene",
      "call": "scene.create",
      "args": {
        "path": "Assets/Scenes/CliUiTouchSmoke.unity"
      }
    },
    {
      "id": "canvas",
      "call": "ui.canvas.create",
      "args": {
        "name": "CliCanvas"
      }
    },
    {
      "id": "button",
      "call": "ui.button.create",
      "args": {
        "canvasName": "CliCanvas",
        "name": "CliButton",
        "text": "Tap Me",
        "anchoredPosition": [
          0,
          0
        ],
        "size": [
          220,
          80
        ]
      }
    },
    {
      "id": "probe",
      "call": "component.update",
      "args": {
        "name": "CliButton",
        "type": "CliUiProbe"
      }
    },
    {
      "id": "tap",
      "call": "ui.click",
      "args": {
        "normalizedPosition": [
          0.5,
          0.5
        ]
      }
    },
    {
      "id": "wait-click",
      "waitFor": {
        "type": "console.log",
        "contains": "CliUiProbe click CliButton",
        "timeoutMs": 2000
      }
    },
    {
      "id": "drag",
      "call": "ui.drag",
      "args": {
        "normalizedFrom": [
          0.5,
          0.5
        ],
        "normalizedTo": [
          0.72,
          0.64
        ]
      }
    },
    {
      "id": "wait-drag",
      "waitFor": {
        "type": "console.log",
        "contains": "CliUiProbe end drag CliButton",
        "timeoutMs": 2000
      }
    },
    {
      "id": "sprite",
      "call": "sprite.create",
      "args": {
        "name": "CliSprite",
        "position": [
          2,
          1,
          0
        ],
        "color": "#FF8A00FF"
      }
    },
    {
      "id": "sprite-probe",
      "call": "component.update",
      "args": {
        "name": "CliSprite",
        "type": "CliUiProbe"
      }
    },
    {
      "id": "sprite-tap",
      "call": "input.tap",
      "args": {
        "worldPosition": [
          2,
          1,
          0
        ]
      }
    },
    {
      "id": "wait-sprite",
      "waitFor": {
        "type": "console.log",
        "contains": "CliUiProbe click CliSprite",
        "timeoutMs": 2000
      }
    },
    {
      "id": "sprite-drag",
      "call": "input.drag",
      "args": {
        "worldFrom": [
          2,
          1,
          0
        ],
        "worldTo": [
          2.75,
          1,
          0
        ]
      }
    },
    {
      "id": "wait-sprite-drag",
      "waitFor": {
        "type": "console.log",
        "contains": "CliUiProbe end drag CliSprite",
        "timeoutMs": 2000
      }
    }
  ]
}
